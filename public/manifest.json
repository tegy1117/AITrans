{
  "manifest_version": 3,
  "name": "AI 번역 확장 프로그램",
  "version": "0.1.1",
  "description": "프로바이더, 모델, 프롬프트를 직접 설정할 수 있는 AI 페이지/선택 영역/이미지 번역 확장 프로그램입니다.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "AI 번역기",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
